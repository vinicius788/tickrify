{
  "name": "ticrif-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "engines": {
    "node": ">=18.x",
    "npm": ">=9.x"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/frontend\" \"npm run dev -w apps/backend\"",
    "dev:backend": "npm run dev -w apps/backend",
    "dev:frontend": "npm run dev -w apps/frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "cd apps/backend && npm install && npx prisma generate --schema=./prisma/schema.prisma && npm run build",
    "build:frontend": "cd apps/frontend && npm install && npm run build",
    "postinstall": "npm run postinstall:backend",
    "postinstall:backend": "cd apps/backend && npx prisma generate --schema=./prisma/schema.prisma",
    "migrate": "npm run migrate -w apps/backend",
    "migrate:status": "npm run migrate:status -w apps/backend",
    "migrate:deploy": "npm run migrate:deploy -w apps/backend",
    "worker": "npm run worker -w apps/backend",
    "start:railway": "npm run start:prod -w apps/backend",
    "worker:railway": "npm run worker:prod -w apps/backend",
    "build:railway": "npm run build:backend",
    "studio": "npm run studio -w apps/backend",
    "vercel-build": "npm run build",
    "smoke:api": "node scripts/smoke-api.mjs",
    "smoke:e2e": "node scripts/e2e-staging.mjs",
    "smoke": "bash scripts/smoke.sh",
    "test": "npm test -w apps/backend -- --runInBand"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "concurrently": "^8.2.2"
  },
  "overrides": {
    "@hono/node-server": "1.19.11",
    "@nestjs/cli": {
      "glob": "10.5.0",
      "tmp": "0.2.5",
      "webpack": "5.105.4"
    },
    "@nestjs/cli@10.4.9": {
      "glob": "10.5.0",
      "tmp": "0.2.5",
      "webpack": "5.105.4"
    },
    "@nestjs/platform-express": {
      "multer": "2.1.1"
    },
    "@nestjs/platform-express@10.4.22": {
      "multer": "2.1.1"
    },
    "@prisma/dev": {
      "@hono/node-server": "1.19.11",
      "hono": "4.12.5"
    },
    "@prisma/dev@0.20.0": {
      "@hono/node-server": "1.19.11",
      "hono": "4.12.5"
    },
    "glob": "10.5.0",
    "hono": "4.12.5",
    "inquirer": {
      "tmp": "0.2.5"
    },
    "tailwindcss": {
      "glob": "10.5.0"
    },
    "tmp": "0.2.5",
    "webpack": "5.105.4",
    "rxjs": "7.8.2"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "multer": "^2.1.1",
    "qs": "^6.15.0"
  }
}
