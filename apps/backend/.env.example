# ============================================
# TICKRIFY BACKEND - ENVIRONMENT EXAMPLE
# ============================================

# Runtime
NODE_ENV=development
APP_ENV=dev
PORT=3001
DEMO_MODE=false

# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/ticrif
# Migration URL (recommended for migrate status/deploy; fallback is DATABASE_URL)
MIGRATIONS_DATABASE_URL=postgresql://user:password@localhost:5432/ticrif
DIRECT_URL=postgresql://user:password@localhost:5432/ticrif
# Compatibilidade com provedores que usam nome alternativo
DIRECT_DATABASE_URL=postgresql://user:password@localhost:5432/ticrif

# Queue (required in production)
REDIS_URL=rediss://default:password@host:port
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth (required in production)
CLERK_SECRET_KEY=YOUR_CLERK_SECRET_KEY_HERE
CLERK_JWT_KEY=
CLERK_PUBLISHABLE_KEY=YOUR_CLERK_PUBLISHABLE_KEY_HERE
CLERK_ISSUER=https://your-tenant.clerk.accounts.dev
CLERK_AUTHORIZED_PARTIES=http://localhost:5173
BOOTSTRAP_ADMIN_EMAILS=
ALLOW_LEGACY_AUTH_FALLBACK=false

# Storage (required in production)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=service-key
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=analysis-images
SUPABASE_STORAGE_PUBLIC_BASE_URL=
MAX_IMAGE_UPLOAD_BYTES=10485760

# AI (required in production)
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE
AI_MODEL=gpt-4o

# Billing (required when Stripe is enabled)
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE
STRIPE_PUBLISHABLE_KEY=YOUR_STRIPE_PUBLISHABLE_KEY_HERE
STRIPE_PRICE_PRO_MONTHLY=price_xxxxx_month
STRIPE_PRICE_PRO_ANNUAL=price_xxxxx_year

# App URLs / CORS
APP_URL=http://localhost:5173
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ──────────────────────────────────────────────
# SEGURANÇA — Health Endpoints Internos
# Token para acessar /api/health e /api/health/ready
# Gere com: openssl rand -hex 32
# Sem este valor, os endpoints retornam 403 por padrão (comportamento esperado)
# ──────────────────────────────────────────────
INTERNAL_OPS_TOKEN=

# Product rules
FREE_ANALYSIS_LIMIT_PER_MONTH=3
